{
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,

  "emeraldwalk.runonsave": {
    "commands": [
      {
        "match": "^(?!.*\\.min\\.js$).*\\.js$",
        "cmd": "terser \"${file}\" -o \"${fileDirname}/${fileBasenameNoExtension}.min.js\" -c -m"
      },
      {
        "match": "^(?!.*\\.min\\.css$).*\\.css$",
        "cmd": "cleancss -o \"${fileDirname}/${fileBasenameNoExtension}.min.css\" \"${file}\""
      }
    ]
  }
}